{
  "name": "tree-sitter-neruda",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for Neruda language",
  "main": "bindings/node/index.js",
  "keywords": [
    "tree-sitter",
    "parser",
    "neruda"
  ],
  "author": "Neruda Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/unknown/tree-sitter-neruda"
  },
  "dependencies": {
    "nan": "^2.17.0"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.20.0"
  },
  "tree-sitter": [
    {
      "scope": "source.neruda",
      "file-types": [
        ".nrd"
      ],
      "highlights": [
        "queries/highlights.scm"
      ]
    }
  ]
}
